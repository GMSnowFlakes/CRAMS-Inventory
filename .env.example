# CRAMS Inventory Management System — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env

# ---------------------------------------------------------------
# Application
# ---------------------------------------------------------------
APP_NAME="CRAMS Inventory"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------------
# Database
# Default: SQLite (zero-config for local dev).
# Switch to mysql/pgsql for production by uncommenting below.
# ---------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=crams
# DB_USERNAME=root
# DB_PASSWORD=

# ---------------------------------------------------------------
# Session / Cache / Queue
# ---------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

# ---------------------------------------------------------------
# Redis (optional)
# ---------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# Mail
# Set MAIL_ENABLED=false to disable all outgoing email entirely.
# ---------------------------------------------------------------
MAIL_ENABLED=false
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="CRAMS Inventory"

# ---------------------------------------------------------------
# AWS S3 (optional — for logo/file storage)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
